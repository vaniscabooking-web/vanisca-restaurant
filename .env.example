# ============================================================
# VANISCA RESTAURANT — Environment Variables
# Copy this file to `.env.local` (development) or configure in
# Vercel Project Settings → Environment Variables (production).
# NEVER commit real secrets. .env* files are gitignored.
# ============================================================

# --- Public site config (safe to expose, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SITE_URL=https://www.vanisca.ma
NEXT_PUBLIC_SITE_NAME=Vanisca Restaurant Agadir

# Public contact channels (shown on the website)
NEXT_PUBLIC_CONTACT_EMAIL=vanisca.restaurant@gmail.com
# Call number (tel: links)
NEXT_PUBLIC_PHONE=0528202202
# WhatsApp number in international format without "+" (wa.me links)
NEXT_PUBLIC_WHATSAPP=212611700033
NEXT_PUBLIC_INSTAGRAM=vaniscarestaurant
# Facebook page username (or full URL / numeric page id)
NEXT_PUBLIC_FACEBOOK=vaniscarestaurant

# --- Server-only secrets (NEVER prefixed with NEXT_PUBLIC) ---
# Activepieces webhooks that receive form submissions.
# Live URL format: https://cloud.activepieces.com/api/v1/webhooks/<FLOW_ID>
# Flows: "Vanisca — Reservation" and "Vanisca — Contact" in the Activepieces project.
ACTIVEPIECES_RESERVATION_WEBHOOK_URL=https://cloud.activepieces.com/api/v1/webhooks/0oq7M0Sn0FJiS4G8KqFB0
ACTIVEPIECES_CONTACT_WEBHOOK_URL=https://cloud.activepieces.com/api/v1/webhooks/55MAKgW2843RvXuTnTnPQ

# Shared secret sent in the X-Webhook-Secret header so the workflow can
# verify requests really originate from this website. Must match the
# `expectedSecret` input of the "Verify Secret + Build Row" step in both flows
# (empty = gate disabled).
ACTIVEPIECES_WEBHOOK_SECRET=replace-with-a-long-random-string

# Optional: simple in-memory rate limit window (ms) and max requests
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
